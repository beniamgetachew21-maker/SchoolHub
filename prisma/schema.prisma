// --- 8. EXAMINATION SYSTEM ---
model ExamType {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id    String @id @default(uuid())
  name  String // "Midterm", "Final", "Quiz"
  exams Exam[]
}

model Exam {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String       @id @default(uuid())
  name        String
  examTypeId  String
  sectionId   String
  termId      String
  date        DateTime
  venue       String?
  maxMarks    Float        @default(100)
  passMarks   Float?
  status      String       @default("Scheduled") // "Scheduled", "Ongoing", "Completed", "Published"

  examType    ExamType     @relation(fields: [examTypeId], references: [id])
  section     ClassSection @relation(fields: [sectionId], references: [id])
  term        AcademicTerm @relation(fields: [termId], references: [id])
  subjects    ExamSubject[]
  grades      Grade[]

  @@index([tenantId, sectionId, examTypeId])
}

model ExamSubject {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String  @id @default(uuid())
  examId    String
  courseId  String
  maxMarks  Float   @default(100)
  passMarks Float?  @default(40)

  exam      Exam    @relation(fields: [examId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id])
  results   Grade[]
}

model Grade {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id            String      @id @default(uuid())
  studentId     String
  examId        String
  examSubjectId String
  marksObtained Float
  gradeLetter   String?
  gp            Float?      // Grade Points
  status        String      @default("Draft") // "Draft", "Submitted", "Published"

  student       Student     @relation(fields: [studentId], references: [studentId])
  exam          Exam        @relation(fields: [examId], references: [id])
  examSubject   ExamSubject @relation(fields: [examSubjectId], references: [id])

  @@unique([studentId, examSubjectId, tenantId])
}

model GradingScale {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String @id @default(uuid())
  name     String
  minScore Float  // Percentage e.g. 90
  maxScore Float? // Percentage e.g. 100
  grade    String // e.g. "A+"
  gpaValue Float  // e.g. 4.0
}

model Transcript {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
  studentId   String
  generatedAt DateTime @default(now())
  fileUrl     String?
}

model ReportCard {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
