// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── NEW SYSTEM DOMAINS ──────────────────────────────────────────────────

model User {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  roleId       String
  entityId     String? // studentId or employeeId
  entityType   String? // "Student", "Employee", "Parent"
  language     String   @default("en") // en, am, om
  role         Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  notifications Notification[]
  auditLogs     AuditLog[]
}

model Role {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String       @id @default(uuid())
  name        String
  description String?
  permissions Permission[]
  users       User[]

  @@unique([name, tenantId])
}

model Permission {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id     String @id @default(uuid())
  name   String
  module String
  roles  Role[]

  @@unique([name, tenantId])
}

model AcademicYear {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String         @id @default(uuid())
  name      String
  startDate DateTime
  endDate   DateTime
  status    String         @default("Upcoming")
  terms     AcademicTerm[]
  semesters Semester[]
}

model AcademicTerm {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String       @id @default(uuid())
  yearId    String
  name      String
  startDate DateTime
  endDate   DateTime
  year      AcademicYear @relation(fields: [yearId], references: [id])

  courseOfferings CourseOffering[]
  exams           Exam[]
}

model ClassSection {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id            String    @id @default(uuid())
  className     String
  sectionName   String
  capacity      Int
  headTeacherId String?
  students      Student[]
  courses       Course[]
  classPeriods  ClassPeriod[]
  exams         Exam[]
}

model Course {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String         @id @default(uuid())
  name        String
  code        String         @unique
  description String?
  credits     Float?
  department  String?
  modules     LMSModule[]
  sections    ClassSection[]

  prerequisitesFor CoursePrerequisite[] @relation("CoursePrereqs")
  prerequisites    CoursePrerequisite[] @relation("PrereqFor")
  offerings        CourseOffering[]
  forums           DiscussionForum[]
  classPeriods     ClassPeriod[]
  examSubjects     ExamSubject[]
}

model LMSModule {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String   @id @default(uuid())
  courseId String
  title    String
  order    Int
  lessons  Lesson[]
  course   Course   @relation(fields: [courseId], references: [id])
}

model Lesson {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String       @id @default(uuid())
  moduleId    String
  title       String
  content     String?
  videoUrl    String?
  order       Int
  assignments Assignment[]
  resources   Resource[]
  module      LMSModule    @relation(fields: [moduleId], references: [id])

  quizzes Quiz[]
}

model Assignment {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String       @id @default(uuid())
  lessonId    String
  title       String
  description String?
  dueDate     DateTime
  maxMarks    Float
  submissions Submission[]
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
}

model Submission {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id           String     @id @default(uuid())
  assignmentId String
  studentId    String
  contentUrl   String?
  submittedAt  DateTime   @default(now())
  status       String     @default("Pending")
  marks        Float?
  feedback     String?
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  student      Student    @relation(fields: [studentId], references: [studentId])
}

model Resource {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String @id @default(uuid())
  lessonId String
  title    String
  type     String
  url      String
  lesson   Lesson @relation(fields: [lessonId], references: [id])
}

model AdmissionInterview {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id            String      @id @default(uuid())
  applicationId String
  interviewerId String
  date          DateTime
  status        String      @default("Scheduled")
  score         Float?
  comments      String?
  application   Application @relation(fields: [applicationId], references: [id])
}

model EntranceExam {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id            String      @id @default(uuid())
  applicationId String
  subject       String
  date          DateTime
  marksObtained Float?
  maxMarks      Float
  status        String      @default("Pending")
  application   Application @relation(fields: [applicationId], references: [id])
}

// ─── UPDATED EXISTING MODELS ───────────────────────────────────────────

model Application {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id                  String                @id @default(uuid())
  name                String
  className           String                @map("class")
  date                String
  status              String
  dob                 String
  gender              String
  email               String
  phone               String
  address             String
  parent              String
  parentPhone         String
  birthCertificate    String
  birthCertificateUrl String?
  previousMarksheet   String?
  motherTongue        String?
  specialNeedsType    String?
  region              String?
  isRefugee           Boolean               @default(false)
  interviews          AdmissionInterview[]
  exams               EntranceExam[]
  documents           ApplicationDocument[]
  decision            AdmissionDecision?
  offer               AdmissionOffer?
  waitlistEntry       Waitlist?

  @@index([tenantId])
}

model Student {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  studentId         String                 @id
  admissionNumber   String                 @unique
  name              String
  className         String                 @map("class")
  parent            String
  status            String
  email             String
  avatarUrl         String
  dob               String?
  gender            String?
  address           String?
  enrollmentDate    String?
  allergies         String[]
  conditions        String[]
  bloodGroup        String?
  emergencyName     String?
  emergencyRelation String?
  emergencyPhone    String?
  motherTongue      String?
  specialNeedsType  String?
  region            String?
  isRefugee         Boolean                @default(false)
  sectionId         String?
  section           ClassSection?          @relation(fields: [sectionId], references: [id])
  submissions       Submission[]
  enrollments       Enrollment[]
  studentGuardians  StudentGuardian[]
  studentContact    StudentContact?
  documents         StudentDocument[]
  statusHistory     StudentStatusHistory[]
  healthRecords     StudentHealthRecord[]
  quizAttempts      QuizAttempt[]
  grades            Grade[]
  transportAssignments TransportAssignment[]
  clubMemberships      ClubMembership[]
  mealTokens           MealToken[]
  healthVisitLogs      HealthVisitLog[]

  @@index([tenantId])
}

model Enrollment {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id           String    @id @default(uuid())
  studentId    String
  academicYear String
  className    String
  sectionName  String?
  status       String    @default("Active") // "Active", "Withdrawn", "Promoted", "Repeated"
  startDate    DateTime  @default(now())
  endDate      DateTime?
  student      Student   @relation(fields: [studentId], references: [studentId])
}

model Employee {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  employeeId            String   @id
  employeeCode          String   @unique
  name                  String
  dob                   String
  gender                String
  nationality           String?
  nationalId            String?
  passport              String?
  department            String
  designation           String
  dateOfJoining         String
  email                 String
  status                String
  avatarUrl             String
  salary                Float
  allowances            Float?
  deductions            Float?
  branch                String?
  jobType               String?
  lineManager           String?
  paymentMethod         String?
  payPeriod             String?
  bankAccount           String?
  maritalStatus         String?
  spouseWorking         Boolean?
  spouseFirstName       String?
  spouseMiddleName      String?
  spouseLastName        String?
  spouseBirthDate       String?
  spouseNationality     String?
  spouseNationalId      String?
  spousePassport        String?
  spouseEthnicity       String?
  spouseReligion        String?
  childrenCount         Int?
  blog                  String?
  officePhone           String?
  mobilePhone           String?
  housePhone            String?
  address1              String?
  address2              String?
  city                  String?
  postcode              String?
  state                 String?
  country               String?
  emergencyFirstName    String?
  emergencyMiddleName   String?
  emergencyLastName     String?
  emergencyRelationship String?
  emergencyMobile       String?
  emergencyHouse        String?
  emergencyOffice       String?
  height                Float?
  weight                Float?
  bloodType             String?
  payrollRecords        PayrollRecord[]
  classPeriods          ClassPeriod[]
  clubs                 Club[]

  @@index([tenantId])
}

model Candidate {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  candidateId String @id
  name        String
  position    String
  stage       String
  appliedDate String

  @@index([tenantId])
}

model OnboardingTask {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  taskId     String  @id
  employeeId String
  taskName   String
  status     String
  dueDate    String?

  @@index([tenantId])
}

model LeaveRequest {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  requestId  String @id
  employeeId String
  leaveType  String
  startDate  String
  endDate    String
  daysCount  Int
  reason     String
  status     String

  @@index([tenantId])
}

model LeavePolicy {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String @id
  name        String
  days        Int
  description String
}

model PayrollRecord {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String    @id @default(uuid())
  employeeId  String
  month       String    // e.g. "2024-09"
  basicSalary Float
  allowances  Float     @default(0)
  deductions  Float     @default(0)
  netSalary   Float
  status      String    @default("Pending") // "Pending", "Paid"
  paidDate    DateTime?
  employee    Employee  @relation(fields: [employeeId], references: [employeeId])

  @@unique([employeeId, month, tenantId])
  @@index([tenantId])
}

model StudentLeaveRequest {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  requestId String @id
  studentId String
  leaveType String
  startDate String
  endDate   String
  daysCount Int
  status    String
  reason    String
}

model Book {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  bookId          Int    @id @default(autoincrement())
  title           String
  author          String
  isbn            String
  genre           String
  totalCopies     Int
  availableCopies Int
}

model BorrowRecord {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  recordId   Int     @id @default(autoincrement())
  studentId  String
  bookId     Int
  borrowDate String
  dueDate    String
  returnDate String?
}

model BorrowRequest {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  requestId   String @id
  studentId   String
  bookId      Int
  requestDate String
  status      String
}

model Invoice {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  invoiceId   String  @id
  studentId   String
  amount      Float
  dueDate     String
  status      String
  description String?
  
  items       InvoiceItem[]
}

model InvoiceItem {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String  @id @default(uuid())
  invoiceId String
  type      String  // e.g., "Tuition", "Transport", "Library"
  amount    Float

  invoice   Invoice @relation(fields: [invoiceId], references: [invoiceId], onDelete: Cascade)
}

model Payment {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  paymentId String @id
  studentId String
  invoiceId String
  amount    Float
  date      String
  method    String
}

model Transaction {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String @id
  date        String
  description String
  type        String
  amount      Float
  method      String
  
  ledgerId    String?
  ledger      Ledger? @relation(fields: [ledgerId], references: [id])
  reference   String?
}

model Ledger {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
  name        String   @map("account_name")
  type        String   // "Income", "Expense", "Asset", "Liability"

  transactions Transaction[]
}

model FeeStructure {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  structureId String @id
  name        String
  baseAmount  Float?
  currency    String? @default("ETB")
  items       Json?
}

model Vehicle {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  vehicleId     String  @id
  vehicleNumber String
  model         String
  capacity      Int
  status        String
  driverId      String?
}

model Driver {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  driverId      String @id
  name          String
  licenseNumber String
  phone         String
  status        String
}

model Route {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  routeId   String @id
  routeName String
  vehicleId String
  driverId  String
  stops     Int
  students  Int
  status    String

  assignments TransportAssignment[]
  logs        TransportLog[]
}

model Classroom {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  roomId String  @id
  name   String
  isLab  Boolean
  classPeriods ClassPeriod[]
}

model Subject {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  subjectId String @id
  name      String
  teacherId String
}

model Hostel {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  hostelId      String @id
  name          String
  hostelType    String @map("type")
  wardenId      String
  totalRooms    Int
  occupiedRooms Int

  rooms           Room[]
  maintenanceLogs HostelMaintenance[]
}

model Room {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  roomId     String  @id
  hostelId   String
  hostel     Hostel  @relation(fields: [hostelId], references: [hostelId])
  roomNumber String
  roomType   String  @map("type")
  status     String
  studentId  String?

  beds Bed[]
}

model TransportAssignment {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
  studentId   String
  routeId     String
  pickupPoint String?
  status      String   @default("Active")
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [studentId])
  route   Route   @relation(fields: [routeId], references: [routeId])

  @@unique([studentId, routeId])
}

model TransportLog {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  routeId   String
  studentId String?
  event     String
  location  String?
  timestamp DateTime @default(now())

  route Route @relation(fields: [routeId], references: [routeId])
}

model InventoryItem {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  itemId          String  @id
  name            String
  category        String
  quantity        Int
  status          String
  purchasePrice   Float?
  purchaseDate    String?
  warrantyEndDate String?
  imageUrl        String?
  imageHint       String?
  isForSale       Boolean
}

model AssetAllocation {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  allocationId String  @id
  itemId       String
  assigneeId   String
  assigneeType String
  issueDate    String
  dueDate      String
  returnDate   String?
}

model Vendor {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  vendorId      String @id
  name          String
  contactPerson String
  email         String
  phone         String
}

model PurchaseOrder {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  poId        String @id
  vendorId    String
  orderDate   String
  items       Json
  totalAmount Float
  status      String
}

model Alumni {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  alumniId        String  @id
  name            String
  graduationYear  Int
  major           String
  currentCompany  String
  currentPosition String
  email           String
  linkedinUrl     String?
  avatarUrl       String
}

model Club {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  clubId           String @id
  name             String
  description      String
  facultyAdvisorId String
  advisor          Employee @relation(fields: [facultyAdvisorId], references: [employeeId])
  memberCount      Int
  category         String?
  color            String? @default("from-blue-500 to-indigo-600")
  iconName         String? @default("Users")
  imageUrl         String
  imageHint        String

  memberships ClubMembership[]
  attendance  ClubAttendanceRecord[]
}

model ClubMembership {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  clubId    String
  studentId String
  role      String   @default("Member") // "Member", "President", "Secretary"
  joinedAt  DateTime @default(now())

  club    Club    @relation(fields: [clubId], references: [clubId])
  student Student @relation(fields: [studentId], references: [studentId])

  @@unique([clubId, studentId, tenantId])
}

model ClubAttendanceRecord {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  clubId    String
  studentId String
  date      DateTime
  status    String   @default("Present") // "Present", "Absent"

  club Club @relation(fields: [clubId], references: [clubId])

  @@index([clubId, date, tenantId])
}

model SubscriberList {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id              String @id
  name            String
  subscriberCount Int
}

model Achievement {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  achievementId String @id
  studentId     String
  achievement   String
  date          String
  category      String
}

model DisciplinaryRecord {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  recordId    String @id
  studentId   String
  date        String
  incident    String
  actionTaken String
  reportedBy  String
  severity    String
}

model Assessment {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  assessmentId String  @id
  name         String
  type         String
  subject      String
  maxMarks     Int
  date         String
  isCCA        Boolean @default(false)
}

model AssessmentResult {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  resultId      String  @id
  assessmentId  String
  studentId     String
  marksObtained Float
  grade         String
  remarks       String?
}

model AttendanceSummary {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  studentId   String @id
  totalDays   Int
  presentDays Int
  absentDays  Int
  leaveDays   Int
}

model ClassPeriod {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id            String       @id @default(uuid())
  sectionId     String
  courseId      String
  teacherId     String
  roomId        String
  dayOfWeek     Int          // 1 = Monday, 5 = Friday
  startTime     String       // e.g., "08:00"
  endTime       String       // e.g., "08:45"
  
  section       ClassSection @relation(fields: [sectionId], references: [id])
  course        Course       @relation(fields: [courseId], references: [id])
  teacher       Employee     @relation(fields: [teacherId], references: [employeeId])
  room          Classroom    @relation(fields: [roomId], references: [roomId])

  @@unique([roomId, dayOfWeek, startTime, tenantId], name: "room_time_conflict")
  @@unique([teacherId, dayOfWeek, startTime, tenantId], name: "teacher_time_conflict")
  @@unique([sectionId, dayOfWeek, startTime, tenantId], name: "section_time_conflict")
}

// --- 0. SAAS CORE: MULTI-TENANCY ---
model Tenant {
  id           String   @id @default(uuid())
  name         String // e.g. "Addis Ababa Academy"
  domain       String?  @unique
  contactEmail String
  contactPhone String?
  address      String?
  logoUrl      String?
  institutionType String? // e.g., "Primary School", "High School", "University"
  language        String   @default("English")
  calendarSystem  String   @default("Gregorian") // "Gregorian", "Ethiopian"
  status       String   @default("Active") // "Active", "Suspended"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  subscriptionId String?
  subscription   TenantSubscription? @relation(fields: [subscriptionId], references: [id])

  // Inverse Relations for Data Isolation
  users                       User[]
  roles                       Role[]
  permissions                 Permission[]
  academicYears               AcademicYear[]
  academicTerms               AcademicTerm[]
  classSections               ClassSection[]
  courses                     Course[]
  lMSModules                  LMSModule[]
  lessons                     Lesson[]
  assignments                 Assignment[]
  submissions                 Submission[]
  resources                   Resource[]
  admissionInterviews         AdmissionInterview[]
  entranceExams               EntranceExam[]
  applications                Application[]
  students                    Student[]
  enrollments                 Enrollment[]
  employees                   Employee[]
  candidates                  Candidate[]
  onboardingTasks             OnboardingTask[]
  leaveRequests               LeaveRequest[]
  leavePolicys                LeavePolicy[]
  studentLeaveRequests        StudentLeaveRequest[]
  books                       Book[]
  borrowRecords               BorrowRecord[]
  borrowRequests              BorrowRequest[]
  invoices                    Invoice[]
  payments                    Payment[]
  transactions                Transaction[]
  feeStructures               FeeStructure[]
  vehicles                    Vehicle[]
  drivers                     Driver[]
  routes                      Route[]
  classrooms                  Classroom[]
  subjects                    Subject[]
  supportTickets              SupportTicket[]
  integrationConfigs          IntegrationConfig[]
  globalAuditLogs             GlobalAuditLog[]
  hostels                     Hostel[]
  rooms                       Room[]
  inventoryItems              InventoryItem[]
  assetAllocations            AssetAllocation[]
  vendors                     Vendor[]
  purchaseOrders              PurchaseOrder[]
  alumnis                     Alumni[]
  clubs                       Club[]
  clubMemberships             ClubMembership[]
  clubAttendance              ClubAttendanceRecord[]
  subscriberLists             SubscriberList[]
  achievements                Achievement[]
  disciplinaryRecords         DisciplinaryRecord[]
