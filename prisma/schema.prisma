// --- 3. STUDENT MANAGEMENT (SIS) ADDITIONS ---
model Guardian {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id               String            @id @default(uuid())
  firstName        String
  lastName         String
  email            String?
  phone            String
  profession       String?
