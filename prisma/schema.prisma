  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id         String   @id @default(uuid())
  bookId     Int
  borrowerId String
  status     String // "Pending", "Fulfilled", "Cancelled"
  createdAt  DateTime @default(now())
}

model LibraryMember {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String   @id @default(uuid())
  userId   String   @unique
  maxBooks Int      @default(3)
  joinedAt DateTime @default(now())
}

// --- 13. HOSTEL / DORMITORY ADDITIONS ---
model Bed {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id     String @id @default(uuid())
  roomId String
  room   Room   @relation(fields: [roomId], references: [roomId])
  number String
  status String // "Occupied", "Vacant"
}

model RoomAssignmentLog {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id         String    @id @default(uuid())
  studentId  String
  bedId      String
  assignedAt DateTime  @default(now())
  vacatedAt  DateTime?
}

model HostelFee {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String @id @default(uuid())
  hostelId String
  amount   Float
  termId   String
}

model HostelMaintenance {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id         String    @id @default(uuid())
  hostelId   String
  hostel     Hostel    @relation(fields: [hostelId], references: [hostelId])
  issue      String
  status     String // "Reported", "In Progress", "Resolved"
  reportedAt DateTime  @default(now())
  resolvedAt DateTime?
}

// --- 14. TRANSPORTATION ADDITIONS ---


// --- 15. COMMUNICATION SYSTEM ---
model Message {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String   @id @default(uuid())
  threadId String
  senderId String
  content  String
  sentAt   DateTime @default(now())
}

model MessageThread {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  subject   String
  createdAt DateTime @default(now())
}

model MessageRecipient {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id       String  @id @default(uuid())
  threadId String
  userId   String
  isRead   Boolean @default(false)
}

model EmailLog {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  recipient String
  subject   String
  status    String
  sentAt    DateTime @default(now())
}

model SmsLog {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id      String   @id @default(uuid())
  phone   String
  message String
  status  String
  sentAt  DateTime @default(now())
}

model PushNotification {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id     String   @id @default(uuid())
  userId String
  title  String
  body   String
  sentAt DateTime @default(now())
}

// --- 16. ANALYTICS & REPORTING ---
model Report {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
  name        String
  generatedBy String
  fileUrl     String
  createdAt   DateTime @default(now())
}

model ReportTemplate {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id     String @id @default(uuid())
  name   String
  config Json
}

model AnalyticsEvent {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  eventType String
  userId    String?
  metadata  Json?
  timestamp DateTime @default(now())
}

model Dashboard {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id     String @id @default(uuid())
  roleId String
  layout Json
}

model KpiMetric {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id           String   @id @default(uuid())
  name         String
  value        Float
  calculatedAt DateTime @default(now())
}

model CafeteriaItem {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  name      String
  category  String
  price     Float
  rating    Float    @default(5.0)
  orders    Int      @default(0)
  tag       String?
  tagColor  String?
  isVeg     Boolean  @default(false)
  imageHint String?
  createdAt DateTime @default(now())

  tokens    MealToken[]
}

model MealToken {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id         String   @id @default(uuid())
  studentId  String
  itemId     String
  status     String   @default("Valid") // "Valid", "Used", "Expired"
  issuedAt   DateTime @default(now())
  validUntil DateTime?

  student Student       @relation(fields: [studentId], references: [studentId])
  item    CafeteriaItem @relation(fields: [itemId], references: [id])

  @@index([studentId, status, tenantId])
}

model HealthVisitLog {
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  id        String   @id @default(uuid())
  studentId String
  date      DateTime @default(now())
  reason    String
  treatment String
  notes     String?
  status    String   @default("Completed") // "Completed", "Follow-up Required"

  student Student @relation(fields: [studentId], references: [studentId])

  @@index([studentId, date, tenantId])
}

model CalendarEvent {
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  id          String   @id @default(uuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  type        String   @default("Event") // "Holiday", "Event", "Exam", "Milestone"
}

// ─── SUPER ADMIN SAAS BACKEND MODELS ─────────────────────────────────────

model SupportTicket {
  id        String   @id @default(uuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  userId    String?  // Reference to user reporting the ticket
  subject   String
  body      String
  priority  String   @default("Medium") // Low, Medium, High, Urgent
  status    String   @default("Open") // Open, In Progress, Resolved, Closed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeatureFlag {
  id          String  @id
  name        String
  description String?
  status      String  @default("Alpha") // Alpha, Beta, GA
  rollout     String  @default("0%") // percentage or specific tiers
  active      Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntegrationConfig {
  id         String   @id @default(uuid())
  tenantId   String?  // If null, it's global Platform integration config
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  provider   String   // Stripe, Twilio, SendGrid
  apiKey     String?
  apiSecret  String?
  webhookUrl String?
  status     String   @default("Disconnected")
  env        String   @default("Test") // Test, Live
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([tenantId, provider])
}

model SubscriptionPlan {
  id          String   @id @default(uuid())
  name        String   @unique
  price       Float
  period      String   @default("Month")
  description String?
  features    String[]
  maxStudents Int?
  badge       String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GlobalAuditLog {
  id         String   @id @default(uuid())
  tenantId   String?
  tenant     Tenant?  @relation(fields: [tenantId], references: [id])
  actorId    String?  // Who did it
  actorIp    String?
  action     String   // "Log In", "Export", "Delete"
  target     String?  // What was affected
  severity   String   @default("Info") // Info, Warning, Critical
  createdAt  DateTime @default(now())
}
